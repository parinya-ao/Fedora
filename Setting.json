{
    // ================================================
    // 🚀 POWERFUL PRODUCTIVITY CORE SETTINGS
    // ================================================
    "editor.acceptSuggestionOnEnter": "smart", // Smart enter for suggestions
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit",
        "source.removeUnusedImports": "explicit",
        "source.addMissingImports": "explicit" // Auto import missing modules
    },
    // ================================================
    // 🔥 SUPER INTELLIGENT AUTO SUGGESTIONS
    // ================================================
    "editor.inlayHints.enabled": "on",
    "editor.inlayHints.fontSize": 12,
    "editor.suggest.showInlineDetails": true,
    "editor.suggest.preview": true,
    "editor.suggest.previewMode": "prefix",
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggest.showMethods": true,
    "editor.suggest.showFunctions": true,
    "editor.suggest.showConstructors": true,
    "editor.suggest.showFields": true,
    "editor.suggest.showVariables": true,
    "editor.suggest.showClasses": true,
    "editor.suggest.showStructs": true,
    "editor.suggest.showInterfaces": true,
    "editor.suggest.showModules": true,
    "editor.suggest.showProperties": true,
    "editor.suggest.showEvents": true,
    "editor.suggest.showOperators": true,
    "editor.suggest.showUnits": true,
    "editor.suggest.showValues": true,
    "editor.suggest.showConstants": true,
    "editor.suggest.showEnums": true,
    "editor.suggest.showEnumMembers": true,
    "editor.suggest.showKeywords": true,
    "editor.suggest.showColors": true,
    "editor.suggest.showFiles": true,
    "editor.suggest.showReferences": true,
    "editor.suggest.showCustomcolors": true,
    "editor.suggest.showFolders": true,
    "editor.suggest.showTypeParameters": true,
    "editor.suggest.showSnippets": true,
    "editor.suggest.showUsers": false, // Disable user suggestions
    "editor.suggest.showIssues": true,
    "editor.suggest.filterGraceful": true, // Smart filtering
    "editor.suggest.matchOnWordStartOnly": false, // Better matching
    "editor.suggest.insertMode": "insert", // Insert mode for suggestions
    "editor.quickSuggestions": {
        "other": "on", // Keep intelligent suggestions
        "comments": "on", // Allow suggestions in comments
        "strings": "on" // Allow suggestions in strings
    },
    "editor.wordBasedSuggestions": "allDocuments", // Use all open documents
    "editor.wordBasedSuggestionsMode": "allDocuments",
    "editor.acceptSuggestionOnCommitCharacter": true,
    "editor.suggestSelection": "first", // Always select first suggestion
    "editor.tabCompletion": "on", // Tab completion
    "editor.emptySelectionClipboard": false, // Performance optimization
    "editor.quickSuggestionsDelay": 0, // ไม่มีดีเลย์ suggestion เลย
    "editor.hover.delay": 50, // Hover เร็วสุดๆ
    "editor.hover.sticky": true, // Keep hover visible
    // ================================================
    // 🚫 GITHUB COPILOT DISABLED - IntelliSense Only
    // ================================================
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",
    "editor.autoIndent": "full",
    "editor.autoSurround": "languageDefined",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.guides.indentation": true,
    "editor.guides.bracketPairsHorizontal": true,
    "editor.linkedEditing": true,
    "editor.matchBrackets": "always",
    "editor.minimap.enabled": false, // Disabled for performance
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "editor.minimap.side": "right",
    "editor.parameterHints.enabled": true,
    "editor.renderControlCharacters": true,
    "editor.renderWhitespace": "boundary",
    "editor.selectionHighlight": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.showFoldingControls": "always",
    "editor.snippetSuggestions": "top",
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 5,
    "editor.suggestOnTriggerCharacters": true,
    "editor.wordWrap": "on",
    "editor.wordWrapColumn": 120,
    "editor.wrappingIndent": "indent",
    "editor.rulers": [
        80,
        120
    ],
    "editor.fontSize": 14,
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Ubuntu Mono', monospace",
    "editor.fontLigatures": true,
    "editor.lineHeight": 1.5,
    "editor.cursorBlinking": "solid", // Optimized for performance
    "editor.cursorSmoothCaretAnimation": "off", // Disabled for performance
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    "editor.tabSize": 4,
    // ================================================
    // GITHUB COPILOT DISABLED - Use VS Code IntelliSense Only
    // ================================================
    "github.copilot.enable": {
        "*": false
    },
    // ================================================
    // WORKBENCH & UI SETTINGS
    // ================================================
    "workbench.colorTheme": "Visual Studio Dark",
    "workbench.iconTheme": "vs-seti",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabSizing": "fit",
    "workbench.startupEditor": "newUntitledFile",
    "workbench.tree.indent": 20,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.activityBar.location": "top",
    "workbench.sideBar.location": "left",
    "workbench.panel.defaultLocation": "bottom",
    "workbench.statusBar.visible": true,
    "workbench.commandPalette.experimental.suggestCommands": true,
    // ================================================
    // EXPLORER & FILE MANAGEMENT
    // ================================================
    "explorer.autoReveal": true,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.incrementalNaming": "smart",
    "explorer.openEditors.visible": 10,
    "explorer.sortOrder": "type",
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.defaultLanguage": "plaintext",
    "files.enableTrash": true,
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.vscode": false
    },
    "files.associations": {
        "*.toml": "toml",
        "*.yaml": "yaml",
        "*.yml": "yaml",
        "*.json": "jsonc",
        "*.js": "javascript",
        "*.ts": "typescript",
        "*.jsx": "javascriptreact",
        "*.tsx": "typescriptreact",
        "*.vue": "vue",
        "*.svelte": "svelte",
        "*.rs": "rust",
        "*.c": "c",
        "*.cpp": "cpp",
        "*.h": "c",
        "*.hpp": "cpp",
        "*.py": "python",
        "*.kt": "kotlin",
        "*.kts": "kotlin",
        "*.gradle": "groovy",
        "*.gradle.kts": "kotlin",
        "Dockerfile*": "dockerfile",
        "*.ino": "cpp",
        "*.pde": "cpp"
    },
    // ================================================
    // SEARCH & REPLACE
    // ================================================
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/target": true,
        "**/dist": true,
        "**/build": true,
        "**/.next": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/*.pyc": true
    },
    "search.useIgnoreFiles": true,
    "search.useGlobalIgnoreFiles": true,
    "search.followSymlinks": false,
    "search.smartCase": true,
    "search.seedOnFocus": true,
    "search.seedWithNearestWord": true,
    // ================================================
    // TERMINAL SETTINGS
    // ================================================
    "terminal.integrated.shell.linux": "/usr/bin/fish",
    "terminal.integrated.defaultProfile.linux": "fish",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', 'Ubuntu Mono', monospace",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.rightClickBehavior": "paste",
    "terminal.integrated.confirmOnExit": "hasChildProcesses",
    "terminal.integrated.enableVisualBell": false,
    "accessibility.signals.terminalBell": {
        "sound": "off"
    },
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.location": "left",
    // ================================================
    // DEBUG SETTINGS
    // ================================================
    "debug.inlineValues": "on",
    "debug.showInStatusBar": "always",
    "debug.toolBarLocation": "floating",
    "debug.console.fontSize": 14,
    "debug.console.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
    "debug.terminal.clearBeforeReusing": true,
    "debug.onTaskErrors": "showErrors",
    "debug.openDebugConsole": "openOnSessionStart",
    "debug.showBreakpointsInOverviewRuler": true,
    "debug.showInlineBreakpointCandidates": true,
    // ================================================
    // SMART GIT SETTINGS - Ultimate Intelligence
    // ================================================
    // ==== AUTO-FETCH & SYNC INTELLIGENCE ====
    "git.autofetch": true,
    "git.autofetchPeriod": 120, // Fetch every 2 minutes for latest updates
    "git.autorefresh": true,
    "git.autoRepositoryDetection": true,
    "git.autoStash": true, // Auto-stash uncommitted changes when switching branches
    "git.branchProtection": [],
    "git.branchProtectionPrompt": "alwaysPrompt",
    "git.confirmSync": false,
    "git.confirmForcePush": true,
    "git.confirmEmptyCommits": true,
    "git.detectSubmodules": true,
    "git.detectSubmodulesLimit": 10,
    "git.fetchOnPull": true,
    "git.followTagsWhenSync": true,
    "git.pruneOnFetch": true, // Auto-clean remote tracking branches
    "git.pullBeforeCheckout": true,
    "git.rebaseWhenSync": true, // Use rebase instead of merge for cleaner history
    "git.requireGitSuffix": false,
    "git.showProgress": true,
    "git.supportCancellation": true,
    "git.useCommitInputAsStashMessage": true,
    "git.useForcePushWithLease": true, // Safer force push
    "git.useIntegratedAskPass": true,
    "git.verboseCommit": true,
    // ==== SMART COMMIT INTELLIGENCE ====
    "git.enableSmartCommit": true,
    "git.smartCommitChanges": "all", // Include all changes in smart commits
    "git.suggestSmartCommit": true,
    "git.enableCommitSigning": true, // GPG signing for security
    "git.alwaysSignOff": true, // Add Signed-off-by line
    "git.allowForcePush": false, // Prevent accidental force push
    "git.allowNoVerifyCommit": false, // Always run pre-commit hooks
    "git.postCommitCommand": "none",
    "git.promptToSaveFilesBeforeCommit": "always",
    "git.promptToSaveFilesBeforeStash": "always",
    "git.showCommitInput": true,
    "git.showInlineOpenFileAction": true,
    "git.showPushSuccessNotification": true,
    "git.showUnpublishedCommitsButton": "always",
    "git.showUntracked": true,
    "git.untrackedChanges": "mixed", // Show untracked files in changes view
    "git.useEditorAsCommitInput": true,
    // ==== ADVANCED BRANCHING INTELLIGENCE ====
    "git.branchRandomName.enable": true,
    "git.branchSortOrder": "committerdate", // Sort branches by most recent commits
    "git.branchValidationRegEx": "^(feature|bugfix|hotfix|release|develop|main|master)\/[a-z0-9\\-]+$",
    "git.branchWhitespaceChar": "-",
    "git.checkoutType": [
        "local",
        "remote",
        "tags"
    ],
    "git.closeDiffOnOperation": true,
    "git.defaultBranchName": "main",
    "git.defaultCloneDirectory": "~/workspace",
    "git.mergeEditor": true, // Use VS Code's 3-way merge editor
    "git.openDiffOnClick": true,
    "git.showActionButton": {
        "commit": true,
        "publish": true,
        "sync": true
    },
    // ==== TIMELINE & HISTORY INTELLIGENCE ====
    "git.timeline.enabled": true,
    "git.timeline.date": "committed",
    "git.timeline.showAuthor": true,
    "git.timeline.showUncommitted": true,
    // ==== REPOSITORY DISCOVERY & MANAGEMENT ====
    "git.openRepositoryInParentFolders": "always",
    "git.repositoryScanIgnoredFolders": [
        "node_modules",
        "target",
        "build",
        "dist",
        ".next",
        ".nuxt",
        "venv",
        "env",
        "__pycache__",
        ".pytest_cache",
        ".vscode"
    ],
    "git.repositoryScanMaxDepth": 3,
    "git.scanRepositories": [
        "~/workspace",
        "~/projects",
        "~/dev"
    ],
    // ==== VISUAL & UI INTELLIGENCE ====
    "git.decorations.enabled": true,
    "git.enableStatusBarSync": true,
    "git.ignoreRebaseWarning": true,
    "git.ignoreLegacyWarning": true,
    "git.ignoreLimitWarning": true,
    "git.ignoreMissingGitWarning": true,
    "git.showTags": true,
    "git.showIncomingChanges": "always",
    "git.showOutgoingChanges": "always",
    // ==== DIFF & COMPARISON INTELLIGENCE ====
    "diffEditor.codeLens": true,
    "diffEditor.diffAlgorithm": "advanced", // Better diff algorithm
    "diffEditor.experimental.showMoves": true, // Show moved code blocks
    "diffEditor.hideUnchangedRegions.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.maxComputationTime": 5000,
    "diffEditor.renderIndicators": true,
    "diffEditor.renderMarginRevertIcon": true,
    "diffEditor.renderSideBySide": true,
    "diffEditor.wordWrap": "on",
    // ==== SCM (Source Control) INTELLIGENCE ====
    "scm.autoReveal": true,
    "scm.countBadge": "all", // Show count of all changes
    "scm.defaultViewMode": "tree", // Tree view for better organization
    "scm.defaultViewSortKey": "status", // Sort by change status
    "scm.diffDecorations": "all",
    "scm.diffDecorationsGutterAction": "diff",
    "scm.diffDecorationsGutterPattern": {
        "added": true,
        "modified": true
    },
    "scm.diffDecorationsGutterVisibility": "always",
    "scm.diffDecorationsGutterWidth": 3,
    "scm.diffDecorationsIgnoreTrimWhitespace": "false",
    "scm.inputFontFamily": "'JetBrains Mono', 'Fira Code', monospace",
    "scm.inputFontSize": 14,
    "scm.providerCountBadge": "auto",
    "scm.showActionButton": true,
    "scm.showChangesSummary": true,
    "scm.showIncomingChanges": "always",
    "scm.showOutgoingChanges": "always",
    "scm.workingSets.enabled": true,
    "scm.workingSets.default": "current",
    // ==== GITGRAPH & VISUALIZATION ====
    "git.graph.branches.showRemoteBranches": true,
    "git.graph.commits.showSignatureStatus": true,
    "git.graph.dateFormat": "relative",
    "git.graph.defaultColumnVisibility": {
        "Date": true,
        "Author": true,
        "Commit": true,
        "Description": true
    },
    "git.graph.maxDepthOfRepoSearch": 2,
    "git.graph.showCommitsOnlyReferencedByTags": true,
    "git.graph.showRemoteBranches": true,
    "git.graph.showStashes": true,
    "git.graph.showTags": true,
    "git.graph.showUncommittedChanges": true,
    // ==== MERGE CONFLICTS INTELLIGENCE ====
    "merge-conflict.autoNavigateNextConflict.enabled": true,
    "merge-conflict.codeLens.enabled": true,
    "merge-conflict.decorators.enabled": true,
    "merge-conflict.diffViewPosition": "Below",
    // ==== GITIGNORE INTELLIGENCE ====
    "gitignore.cacheExpirationInterval": 3600, // Cache for 1 hour
    // ==== GITLENS INTEGRATION (if available) ====
    "gitlens.autolinks": [
        {
            "prefix": "#",
            "url": "https://github.com/<repo>/issues/<num>",
            "title": "Open Issue #<num>"
        },
        {
            "prefix": "PR #",
            "url": "https://github.com/<repo>/pull/<num>",
            "title": "Open Pull Request #<num>"
        }
    ],
    "gitlens.blame.compact": false,
    "gitlens.blame.highlight.enabled": true,
    "gitlens.blame.highlight.locations": [
        "gutter",
        "line",
        "overview"
    ],
    "gitlens.codeLens.enabled": true,
    "gitlens.codeLens.authors.enabled": true,
    "gitlens.codeLens.recentChange.enabled": true,
    "gitlens.currentLine.enabled": true,
    "gitlens.currentLine.pullRequests.enabled": true,
    "gitlens.defaultDateFormat": "MMMM Do, YYYY h:mma",
    "gitlens.defaultDateShortFormat": "MMM D, YYYY",
    "gitlens.defaultTimeFormat": "h:mma",
    "gitlens.hovers.enabled": true,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.statusBar.enabled": true,
    "gitlens.views.repositories.enabled": true,
    "gitlens.views.fileHistory.enabled": true,
    "gitlens.views.lineHistory.enabled": true,
    // ==== GIT WORKFLOW AUTOMATION ====
    "git.workflows.enabled": true,
    "git.workflows.pullRequestReviewMode": true,
    "git.workflows.autoCreateBranch": true,
    "git.workflows.branchNaming": {
        "feature": "feature/{ticket}-{description}",
        "bugfix": "bugfix/{ticket}-{description}",
        "hotfix": "hotfix/{ticket}-{description}",
        "release": "release/{version}"
    },
    // ==== SECURITY & BEST PRACTICES ====
    "git.alwaysShowStagedChangesResourceGroup": true,
    "git.confirmNoVerifyCommit": true,
    "git.inputValidation": true,
    "git.inputValidationLength": 72, // Standard commit message length
    "git.inputValidationSubjectLength": 50, // Subject line length
    "git.terminalAuthentication": true,
    "git.terminalGitEditor": true,
